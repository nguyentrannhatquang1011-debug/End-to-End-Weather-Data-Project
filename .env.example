# ==========================================
# THÔNG TIN ENV DỰ ÁN
# ==========================================
KAFKA_BOOTSTRAP_SERVERS=

# Airflow Variables
AIRFLOW_UID=
AIRFLOW_PROJ_DIR=.
_AIRFLOW_WWW_USER_USERNAME=
_AIRFLOW_WWW_USER_PASSWORD=

# Postgres Variables
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# MinIO Variables
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# InfluxDB Variables
# ---------------------------------------------------------
# Phần này dùng để Docker tự động khởi tạo database lần đầu
INFLUXDB_INIT_MODE=
INFLUXDB_INIT_USERNAME=
INFLUXDB_INIT_PASSWORD=
INFLUXDB_INIT_ORG=
INFLUXDB_INIT_BUCKET=

# ---------------------------------------------------------
# Phần này dùng trong Code Python để kết nối (Đã đồng nhất với phía trên)
INFLUXDB_ADMIN_USER=
INFLUXDB_ADMIN_PASSWORD=
INFLUXDB_ORG=
INFLUXDB_BUCKET=

# Lưu ý: Token này bạn phải lấy từ giao diện web InfluxDB sau khi chạy Docker thành công
INFLUXDB_TOKEN=
INFLUXDB_URL=

# 3. Dịch vụ External API
OPEN_METEO_API_KEY=
AQICN_API_KEY=