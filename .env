# ==========================================
# THÔNG TIN BẢO MẬT DỰ ÁN DATA PIPELINE
# ==========================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Airflow Variables
AIRFLOW_UID=50000
# Đường dẫn này sẽ được gắn vào container Airflow để lưu trữ dữ liệu, logs, v.v. Bạn có thể thay đổi nếu muốn.
# dấu chấm (.) có nghĩa là thư mục hiện tại, tức là thư mục chứa file docker-compose.yml này. 
# Khi Docker chạy, nó sẽ tạo ra các thư mục con như ./dags, ./logs, ./plugins trên máy chủ của bạn để lưu trữ dữ liệu của Airflow.
AIRFLOW_PROJ_DIR=. 
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin123456

# Postgres Variables
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow_db

# MinIO Variables
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=minioadmin123

# InfluxDB Variables
# ---------------------------------------------------------
# Phần này dùng để Docker tự động khởi tạo database lần đầu
INFLUXDB_INIT_MODE=setup
INFLUXDB_INIT_USERNAME=admin
INFLUXDB_INIT_PASSWORD=admin123456
INFLUXDB_INIT_ORG=weather_org
INFLUXDB_INIT_BUCKET=weather_data

# ---------------------------------------------------------
# Phần này dùng trong Code Python để kết nối (Đã đồng nhất với phía trên)
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=admin123456
INFLUXDB_ORG=weather_org
INFLUXDB_BUCKET=weather_data

# Lưu ý: Token này bạn phải lấy từ giao diện web InfluxDB sau khi chạy Docker thành công
INFLUXDB_TOKEN=Q5IuDlH0SD3o36t2E2AK21Ny7TbL1zHhsysWJTcxjoTJ6p3lF53qBbQaemHM8XlQreQ1YgfgzBQfrA934AyGZw==
INFLUXDB_URL=http://influxdb:8086

# 3. Dịch vụ External API
OPEN_METEO_API_KEY=your_api_key_if_needed
AQICN_API_KEY=712f12c6ce7457ae73f182af432166785b5b52ac